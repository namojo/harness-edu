{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "규제·공시 모니터링 결과",
  "description": "codex exec --output-schema 로 최종 응답 형태를 강제한다. 모델이 이 형태를 벗어나면 재시도된다.",
  "type": "object",
  "required": ["as_of", "items"],
  "properties": {
    "as_of": {
      "type": "string",
      "description": "조사 기준일 (YYYY-MM-DD)"
    },
    "items": {
      "type": "array",
      "description": "이번 주 포착된 규제·공시 항목",
      "items": {
        "type": "object",
        "required": ["title", "source", "date", "category", "impact", "action"],
        "properties": {
          "title": { "type": "string", "description": "항목 제목 (한 줄)" },
          "source": { "type": "string", "description": "출처 기관/매체명" },
          "date": { "type": "string", "description": "발표일 (YYYY-MM-DD)" },
          "category": {
            "type": "string",
            "enum": ["자본규제", "소비자보호", "AML/제재", "공시", "기타"],
            "description": "분류 — 정해진 값만 허용 (자유 서술 금지)"
          },
          "impact": {
            "type": "string",
            "enum": ["높음", "중간", "낮음"],
            "description": "우리 조직 영향도"
          },
          "action": {
            "type": "string",
            "description": "실행 가능한 다음 행동 (검토 필요 같은 무책임 동사 금지)"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
